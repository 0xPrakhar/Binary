# //this is for local development. In production, the frontend will be served by the backend, so we can use relative paths to talk to the backend API. But in development, the frontend is served by Vite on a different port (5000), so we need to specify the backend URL here.
VITE_API_URL=http://localhost:5000
# // In production, you would set this to the actual URL of your backend, e.g. https://your-backend-url
# VITE_API_URL = https://your-backend-url